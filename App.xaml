<Application x:Class="ClipPlusPlus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClipPlusPlus"
             xmlns:tb="http://github.com/Hearthy/H.NotifyIcon"
             xmlns:vm="clr-namespace:ClipPlusPlus.ViewModels"
             xmlns:Models="clr-namespace:ClipPlusPlus.Models"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <vm:MainViewModel x:Key="MainViewModel" />

            <!-- Converter for boolean to visibility -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- Data template for history items -->
            <DataTemplate x:Key="HistoryItemTemplate">
                <StackPanel Orientation="Horizontal">
                    <!-- Image preview for image items -->
                    <Image Source="{Binding ImagePreview}" 
                           Width="24" Height="24" 
                           Margin="0,0,5,0"
                           Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}" />
                    <!-- Display title (works for both text and image) -->
                    <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center" />
                </StackPanel>
            </DataTemplate>

            <Style x:Key="SnippetItemStyle" TargetType="MenuItem">
                <Setter Property="Header" Value="{Binding Title}" />
                <Setter Property="Command" Value="{Binding PasteItemCommand, Source={StaticResource MainViewModel}}" />
                <Setter Property="CommandParameter" Value="{Binding}" />
                <EventSetter Event="MouseEnter" Handler="MenuItem_MouseEnter" />
            </Style>

            <Style x:Key="SnippetFolderStyle" TargetType="MenuItem">
                <Setter Property="Header" Value="{Binding Name}" />
                <Setter Property="ItemsSource" Value="{Binding Snippets}" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource SnippetItemStyle}" />
                <EventSetter Event="MouseEnter" Handler="MenuItem_MouseEnter" />
            </Style>

            <Style x:Key="HistoryItemStyle" TargetType="MenuItem">
                <Setter Property="Header" Value="{Binding DisplayTitle}" />
                <Setter Property="Command" Value="{Binding PasteItemCommand, Source={StaticResource MainViewModel}}" />
                <Setter Property="CommandParameter" Value="{Binding}" />
                <EventSetter Event="MouseEnter" Handler="MenuItem_MouseEnter" />
                <EventSetter Event="MouseLeave" Handler="MenuItem_MouseLeave" />
                <EventSetter Event="Loaded" Handler="MenuItem_Loaded" />
            </Style>

            <Style x:Key="HistoryGroupStyle" TargetType="MenuItem">
                <Setter Property="Header" Value="{Binding Name}" />
                <Setter Property="ItemsSource" Value="{Binding Items}" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource HistoryItemStyle}" />
                <EventSetter Event="MouseEnter" Handler="MenuItem_MouseEnter" />
            </Style>

            <ContextMenu x:Key="TrayMenu" DataContext="{StaticResource MainViewModel}">
                <!-- History groups will be dynamically added here -->
                <Separator x:Name="HistorySeparator" />
                <MenuItem Header="Snippets" 
                          ItemsSource="{Binding SnippetFolders, Source={StaticResource MainViewModel}}" 
                          ItemContainerStyle="{StaticResource SnippetFolderStyle}" />
                <Separator />
                <MenuItem Header="Settings..." Command="{Binding ShowSettingsCommand, Source={StaticResource MainViewModel}}" />
                <MenuItem Header="Clear History" Command="{Binding ClearHistoryCommand, Source={StaticResource MainViewModel}}" />
                <MenuItem Header="Exit" Command="{Binding ExitCommand, Source={StaticResource MainViewModel}}" />
            </ContextMenu>
        </ResourceDictionary>
    </Application.Resources>
</Application>
